{
  // Docs linting (blueprint §29). Markdown is owned here, not by Prettier.
  "config": {
    "default": true,
    // We do not hard-wrap prose at a fixed column, so line length is not a rule.
    "MD013": false,
    // Docs use inline HTML (details/callouts) where Markdown is insufficient.
    "MD033": false,
    // Some files open with a callout or table rather than a top-level H1.
    "MD041": false,
    // Allow duplicate headings under different parents (e.g. repeated "## Command").
    "MD024": { "siblings_only": true },
    // Table pipe-spacing is cosmetic; Prettier (the usual table formatter) is off for Markdown here.
    "MD060": false,
  },
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules",
    "dist",
    "coverage",
    "tmp",
    ".pnpm-store",
    ".devcontainer",
    ".claude",
    ".idea",
    ".vscode",
    "test/fixtures",
    // Sample vault: plugin-generated card/board content, not authored docs. The
    // serializer (src/model/card.ts) writes `## Heading` directly above its list
    // items and reverts reformats on GUI edit, so MD022/MD032/MD025 don't apply.
    "examples",
    "CHANGELOG.md",
  ],
}
